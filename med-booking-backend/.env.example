# Copia questo file in .env e compila i valori reali
# cp .env.example .env

# Connessione PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=medicapp_db

# Impostare a "true" solo quando ci si collega a un database cloud che richiede SSL (es. Neon).
# In locale con Docker Compose lasciare "false" o non impostarla.
DB_SSL=false

# JWT — scegliere una stringa lunga e casuale in produzione
JWT_SECRET=

# Server
PORT=3000

# CORS (lista separata da virgola — vedi src/main.ts)
# Sviluppo:   CORS_ORIGIN=localhost
# Produzione: CORS_ORIGIN=localhost,https://app.tuodominio.it
CORS_ORIGIN=localhost
